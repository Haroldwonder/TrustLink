DATABASE_URL=postgresql://trustlink:trustlink@localhost:5432/trustlink
CONTRACT_ID=YOUR_CONTRACT_ID_HERE
RPC_URL=https://soroban-testnet.stellar.org
GENESIS_LEDGER=0
START_LEDGER=
PORT=3000
GQL_PORT=4000

# ── Logging (#780) ─────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── GraphQL authentication (#778) ──────────────────────────────────────────────
# Comma-separated list of valid API keys. Leave unset to disable auth.
# Example: GRAPHQL_API_KEYS=key1,key2
GRAPHQL_API_KEYS=

# ── GraphQL query limits (#779) ────────────────────────────────────────────────
# Maximum query depth (default: 7)
GRAPHQL_MAX_DEPTH=7
# Maximum query complexity score (default: 1000)
GRAPHQL_MAX_COMPLEXITY=1000

# ── OpenTelemetry tracing (#781) ───────────────────────────────────────────────
# OTLP collector endpoint. Leave unset to disable tracing.
# Example: http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# Event Archival Configuration
# How often to run archival job (hours)
ARCHIVAL_INTERVAL_HOURS=6

# Archive destination (local path, s3://, or gs://)
# Local: /archive/trustlink-events or /mnt/archive
# S3:    s3://trustlink-events-archive
# GCS:   gs://trustlink-events-archive
ARCHIVE_PATH=s3://trustlink-events-archive

# AWS credentials (for S3 archival)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Cloud credentials (for GCS archival)
GOOGLE_APPLICATION_CREDENTIALS=
