# TrustLink RPC and contract
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
TRUSTLINK_CONTRACT_ID=C...

# Freelancer address (the subject of all JOB_COMPLETED attestations)
FREELANCER_ADDRESS=G...

# Three client keypairs at different IssuerTier levels.
# All three must be registered as TrustLink issuers and have their tiers
# set by the contract admin before running:
#   set_issuer_tier(admin, CLIENT_A_PUBLIC, Basic)
#   set_issuer_tier(admin, CLIENT_B_PUBLIC, Verified)
#   set_issuer_tier(admin, CLIENT_C_PUBLIC, Premium)
CLIENT_A_SECRET=S...   # Basic tier
CLIENT_B_SECRET=S...   # Verified tier
CLIENT_C_SECRET=S...   # Premium tier
