{
  "name": "@trustlink/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the TrustLink on-chain attestation contract on Stellar",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stellar",
    "soroban",
    "attestation",
    "kyc",
    "trustlink"
  ],
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^14.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  }
}
